---
import Layout from "../../layouts/Layout.astro";
import { ACCENT } from "../../data/terminal";
import "../../styles/terminal.css";

if (Astro.locals.user) {
	return Astro.redirect("/admin/tracker");
}
---

<Layout variant="terminal" lang="es" title="Login · Tracker · Wilmer Alama">
	<div
		class="terminal-root login-shell"
		style={`--accent: ${ACCENT}; --accent-rgb: 250 204 21;`}
	>
		<div class="terminal-bg" aria-hidden="true">
			<div class="terminal-bg-layer-gradient"></div>
			<div class="terminal-bg-layer-grid"></div>
			<div class="terminal-bg-layer-grid-accent"></div>
			<div class="terminal-bg-scan"></div>
		</div>

		<div class="terminal-scroll login-scroll">
			<main class="login-page">
				<section class="login-panel" aria-labelledby="login-title">
					<p class="terminal-kicker">// auth · login.sh</p>
					<h1 id="login-title">
						Acceso al <span>Tracker</span>
					</h1>
					<p class="login-lead">
						Inicia sesión para gestionar todos, bitácora y proyectos
						del mes.
					</p>

					<a href="/login/github" class="login-github">
						<svg
							class="login-github-icon"
							fill="currentColor"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path
								fill-rule="evenodd"
								d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
								clip-rule="evenodd"></path>
						</svg>
						Continuar con GitHub
					</a>

					<a href="/" class="login-back">← Volver al portafolio</a>
				</section>
			</main>
		</div>
	</div>
</Layout>

<style>
	.terminal-body .login-shell.terminal-root,
	.login-shell.terminal-root {
		background: #121218;
		color: #f0f0f2;
	}

	.login-shell .terminal-bg-layer-grid {
		background-image:
			linear-gradient(
				to right,
				rgba(255, 255, 255, 0.055) 1px,
				transparent 1px
			),
			linear-gradient(
				to bottom,
				rgba(255, 255, 255, 0.055) 1px,
				transparent 1px
			);
		mask-image: radial-gradient(
			ellipse 90% 80% at 50% 40%,
			black 0%,
			transparent 100%
		);
		-webkit-mask-image: radial-gradient(
			ellipse 90% 80% at 50% 40%,
			black 0%,
			transparent 100%
		);
	}

	.login-shell .terminal-bg-layer-grid-accent {
		background-image:
			linear-gradient(
				to right,
				rgb(var(--accent-rgb) / 0.1) 1px,
				transparent 1px
			),
			linear-gradient(
				to bottom,
				rgb(var(--accent-rgb) / 0.1) 1px,
				transparent 1px
			);
	}

	.login-scroll {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		padding: 32px 20px;
	}

	.login-page {
		position: relative;
		z-index: 2;
		width: min(420px, 100%);
	}

	.login-panel {
		padding: 28px 24px;
		border: 1px solid #34343e;
		background: #1a1a22;
		border-radius: 4px;
	}

	.login-panel h1 {
		margin: 10px 0 0;
		font-size: clamp(1.5rem, 4vw, 1.85rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		color: #f5f5f7;
		line-height: 1.2;
	}

	.login-panel h1 span {
		color: var(--accent);
	}

	.login-lead {
		margin: 12px 0 0;
		font-size: 13px;
		line-height: 1.55;
		color: #b0b0b8;
		max-width: 36ch;
	}

	.login-github {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		margin-top: 28px;
		width: 100%;
		padding: 12px 16px;
		box-sizing: border-box;
		background: var(--accent);
		border: 1px solid var(--accent);
		color: #0a0a0a;
		font-family: inherit;
		font-size: 13px;
		font-weight: 600;
		text-decoration: none;
		transition:
			box-shadow 140ms ease,
			filter 140ms ease;
	}

	.login-github:hover {
		filter: brightness(1.05);
		box-shadow: 0 0 22px rgb(var(--accent-rgb) / 0.28);
	}

	.login-github:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 3px;
	}

	.login-github-icon {
		width: 18px;
		height: 18px;
		flex-shrink: 0;
	}

	.login-back {
		display: inline-block;
		margin-top: 18px;
		font-size: 12px;
		color: #9a9aa3;
		text-decoration: none;
	}

	.login-back:hover {
		color: var(--accent);
	}
</style>
