---
import Layout from "../../../layouts/Layout.astro";

const manga = {
	title: "El Jugador Que No Puede Subir De Nivel",
	altTitle: "The Player That Can't Level Up",
	type: "manhwa",
	genres: ["Acción", "Aventura", "Fantasía", "Webtoon"],
	ranking: 307,
	author: "GaVinGe, Parrot Kim, Studio Khit",
	date: "2021",
	status: "En desarrollo",
	synopsis:
		"Kim GiGyu despertó como jugador a la edad de 18 años. Pensó que su vida estaba encaminada hacia el éxito, escalando 'la torre' y cerrando portales. Sin embargo, incluso después de completar el tutorial, estaba en el nivel 1. Él mató a un goblin por día, y todavía estaba en el nivel 1. Incluso después de 5 años, todavía estaba en el nivel 1. \"¿Es posible que este tipo de jugador existiera?\" Nadie sabía.",
};

const statusButtons = [
	{ label: "Ninguno", count: null, active: true },
	{ label: "Leyendo", count: 347, active: false },
	{ label: "Pendiente", count: 163, active: false },
	{ label: "Leído", count: 28, active: false },
];

const chapters = [
	{ number: 7, title: null, date: "Hace 10 días" },
	{ number: 6, title: null, date: "Hace 14 días" },
	{ number: 5, title: null, date: "Hace 14 días" },
	{ number: 4, title: null, date: "Hace 14 días" },
	{ number: 3, title: "Primer capítulo de la quinta temporada", date: "Hace 14 días" },
	{ number: 2, title: "Aviso - Videojuego", date: "Hace un mes" },
	{ number: 1, title: "Aviso - Fecha de la nueva temporada", date: "Hace un mes" },
];

const navLinks = [
	"Inicio",
	"Lista de manga",
	"Top",
	"Anime",
	"Recientes",
	"Grupos",
	"Listas",
	"Noticias",
];
---

<Layout>
	<div class="manga-page">
		<header class="site-header">
			<div class="header-top">
				<span class="brand-letter">M</span>
				<div class="search-wrap">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="16"
						height="16"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="search-icon"
						aria-hidden="true"
					>
						<path d="m21 21-4.34-4.34"></path>
						<circle cx="11" cy="11" r="8"></circle>
					</svg>
					<input
						type="search"
						class="search-input"
						placeholder="Buscar"
						aria-label="Buscar manga"
					/>
				</div>
			</div>
			<nav class="header-nav" aria-label="Navegación principal">
				<ul class="nav-list">
					{navLinks.map((link) => <li><a href="#" class="nav-link">{link}</a></li>)}
				</ul>
			</nav>
		</header>

		<main class="main-content">
			<!-- Manga info card -->
			<article class="card manga-info-card">
				<div class="manga-layout">
					<div class="cover-wrap">
						<div class="cover-placeholder">
							<span class="cover-letter">M</span>
						</div>
						<span class="badge badge-accent">{manga.type}</span>
					</div>
					<div class="manga-details">
						<h1 class="manga-title">{manga.title}</h1>
						<div class="genre-row">
							{manga.genres.map((g) => <span class="badge badge-secondary">{g}</span>)}
						</div>
						<dl class="meta-list">
							<div class="meta-row">
								<dt>Alterno:</dt>
								<dd>{manga.altTitle}</dd>
							</div>
							<div class="meta-row">
								<dt>Ranking:</dt>
								<dd><span class="badge badge-outline">#{manga.ranking}</span></dd>
							</div>
							<div class="meta-row">
								<dt>Autor:</dt>
								<dd>{manga.author}</dd>
							</div>
							<div class="meta-row">
								<dt>Fecha:</dt>
								<dd>{manga.date}</dd>
							</div>
							<div class="meta-row">
								<dt>Estado:</dt>
								<dd>
									<span class="badge badge-green">{manga.status}</span>
								</dd>
							</div>
						</dl>
						<div class="synopsis">
							<h3 class="synopsis-title">Sinopsis</h3>
							<p class="synopsis-text">{manga.synopsis}</p>
						</div>
					</div>
				</div>
			</article>

			<!-- Reading status card -->
			<article class="card status-card">
				<h2 class="card-title">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						class="icon-star"
						aria-hidden="true"
					>
						<path
							d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"
						></path>
					</svg>
					MARCAR ESTE MANGA COMO
				</h2>
				<div class="status-buttons">
					{
						statusButtons.map((btn) => (
							<button
								type="button"
								class:list={["status-btn", btn.active && "status-btn--active"]}
							>
								{btn.label}
								{btn.count !== null && (
									<span class="badge badge-count">{btn.count}</span>
								)}
							</button>
						))
					}
				</div>
			</article>

			<!-- Chapters card -->
			<article class="card chapters-card">
				<h2 class="card-title">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						width="20"
						height="20"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						aria-hidden="true"
					>
						<path d="M3 5h.01"></path>
						<path d="M3 12h.01"></path>
						<path d="M3 19h.01"></path>
						<path d="M8 5h13"></path>
						<path d="M8 12h13"></path>
						<path d="M8 19h13"></path>
					</svg>
					CAPÍTULOS
				</h2>
				<div class="chapter-list">
					{
						chapters.map((ch) => (
							<a href="#" class="chapter-row">
								<span class="chapter-name">
									Capítulo {ch.number}
									{ch.title && (
										<span class="chapter-subtitle"> — {ch.title}</span>
									)}
								</span>
								<span class="chapter-date">{ch.date}</span>
							</a>
						))
					}
				</div>
			</article>
		</main>
	</div>
</Layout>

<style>
	/* ── Theme tokens ── */
	.manga-page {
		--bg: #0d1117;
		--card: #161b22;
		--primary: #1a3a5c;
		--primary-fg: #f0f6fc;
		--muted: #21262d;
		--muted-fg: #8b949e;
		--border: rgba(240, 246, 252, 0.1);
		--accent: #58a6ff;
		--accent-secondary: #c9a8f5;
		--text: #e6edf3;
		--text-soft: #8b949e;
		--green: #3fb950;
		--green-bg: rgba(63, 185, 80, 0.15);
		--yellow: #d29922;
	}

	/* ── Page shell ── */
	.manga-page {
		min-height: 100vh;
		background: var(--bg);
		color: var(--text);
		font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	/* ── Header ── */
	.site-header {
		background: var(--primary);
		color: var(--primary-fg);
	}

	.header-top {
		max-width: 1120px;
		margin-inline: auto;
		padding: 12px 16px;
		display: flex;
		align-items: center;
		gap: 16px;
	}

	.brand-letter {
		font-size: 1.5rem;
		font-weight: 700;
		flex-shrink: 0;
	}

	.search-wrap {
		flex: 1;
		max-width: 480px;
		position: relative;
	}

	.search-icon {
		position: absolute;
		left: 12px;
		top: 50%;
		transform: translateY(-50%);
		color: rgba(240, 246, 252, 0.5);
		pointer-events: none;
	}

	.search-input {
		width: 100%;
		padding: 7px 12px 7px 36px;
		border-radius: 8px;
		border: none;
		background: rgba(240, 246, 252, 0.12);
		color: var(--primary-fg);
		font-size: 14px;
		outline: none;
	}

	.search-input::placeholder {
		color: rgba(240, 246, 252, 0.5);
	}

	.search-input:focus {
		box-shadow: 0 0 0 2px rgba(88, 166, 255, 0.4);
	}

	.header-nav {
		max-width: 1120px;
		margin-inline: auto;
		padding-inline: 16px;
	}

	.nav-list {
		display: flex;
		gap: 24px;
		padding-block: 8px;
		list-style: none;
		margin: 0;
		overflow-x: auto;
	}

	.nav-link {
		font-size: 13px;
		color: rgba(240, 246, 252, 0.85);
		white-space: nowrap;
		text-decoration: none;
		transition: color 0.15s;
	}

	.nav-link:hover {
		color: var(--primary-fg);
	}

	/* ── Layout ── */
	.main-content {
		max-width: 1120px;
		margin-inline: auto;
		padding: 24px 16px;
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	/* ── Cards ── */
	.card {
		background: var(--card);
		border-radius: 12px;
		padding: 24px;
		border: 1px solid var(--border);
	}

	.card-title {
		display: flex;
		align-items: center;
		gap: 8px;
		font-size: 15px;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 16px;
	}

	/* ── Manga info ── */
	.manga-layout {
		display: flex;
		gap: 24px;
		flex-wrap: wrap;
	}

	.cover-wrap {
		position: relative;
		width: 192px;
		flex-shrink: 0;
	}

	.cover-placeholder {
		aspect-ratio: 3/4;
		border-radius: 10px;
		overflow: hidden;
		background: linear-gradient(135deg, #6e40c9 0%, #1e40af 100%);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.cover-letter {
		color: white;
		font-size: 3rem;
		font-weight: 700;
	}

	.manga-details {
		flex: 1;
		min-width: 0;
	}

	.manga-title {
		font-size: 1.5rem;
		font-weight: 700;
		color: var(--text);
		margin-bottom: 12px;
		line-height: 1.3;
	}

	.genre-row {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-bottom: 16px;
	}

	.meta-list {
		display: flex;
		flex-direction: column;
		gap: 6px;
		margin-bottom: 16px;
	}

	.meta-row {
		display: flex;
		gap: 6px;
		font-size: 13px;
		color: var(--text-soft);
		align-items: center;
		flex-wrap: wrap;
	}

	.meta-row dt {
		font-weight: 600;
		color: var(--text);
	}

	.synopsis-title {
		font-size: 14px;
		font-weight: 600;
		color: var(--text);
		margin-bottom: 8px;
	}

	.synopsis-text {
		font-size: 13px;
		line-height: 1.65;
		color: var(--text-soft);
	}

	/* ── Badges ── */
	.badge {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		border-radius: 6px;
		padding: 2px 8px;
		font-size: 11px;
		font-weight: 500;
		border: 1px solid transparent;
		white-space: nowrap;
	}

	.badge-accent {
		position: absolute;
		top: 8px;
		left: 8px;
		background: rgba(88, 166, 255, 0.2);
		border-color: rgba(88, 166, 255, 0.4);
		color: var(--accent);
	}

	.badge-secondary {
		background: var(--muted);
		color: var(--text);
		border-color: var(--border);
	}

	.badge-outline {
		background: transparent;
		border-color: var(--accent-secondary);
		color: var(--accent-secondary);
	}

	.badge-green {
		background: var(--green-bg);
		border-color: rgba(63, 185, 80, 0.3);
		color: var(--green);
	}

	.badge-count {
		background: transparent;
		border-color: var(--border);
		color: var(--text-soft);
		font-size: 10px;
		margin-left: 4px;
	}

	/* ── Status buttons ── */
	.icon-star {
		color: var(--yellow);
	}

	.status-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
	}

	.status-btn {
		display: inline-flex;
		align-items: center;
		padding: 6px 12px;
		border-radius: 8px;
		font-size: 13px;
		font-weight: 500;
		cursor: pointer;
		border: 1px solid var(--border);
		background: var(--muted);
		color: var(--text);
		transition:
			background 0.15s,
			border-color 0.15s;
	}

	.status-btn:hover {
		background: rgba(88, 166, 255, 0.12);
		border-color: rgba(88, 166, 255, 0.4);
	}

	.status-btn--active {
		background: var(--accent);
		border-color: var(--accent);
		color: #0d1117;
	}

	.status-btn--active:hover {
		background: #79c0ff;
		border-color: #79c0ff;
	}

	/* ── Chapters ── */
	.chapter-list {
		display: flex;
		flex-direction: column;
	}

	.chapter-row {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 12px 8px;
		border-top: 1px solid var(--border);
		border-radius: 6px;
		text-decoration: none;
		transition: background 0.15s;
		margin-inline: -8px;
	}

	.chapter-row:first-child {
		border-top: none;
	}

	.chapter-row:hover {
		background: rgba(240, 246, 252, 0.05);
	}

	.chapter-name {
		font-size: 14px;
		color: var(--text);
	}

	.chapter-subtitle {
		color: var(--text-soft);
	}

	.chapter-date {
		font-size: 12px;
		color: var(--text-soft);
		white-space: nowrap;
		margin-left: 12px;
	}

	/* ── Responsive ── */
	@media (max-width: 640px) {
		.manga-layout {
			flex-direction: column;
		}

		.cover-wrap {
			width: 100%;
			max-width: 192px;
		}

		.manga-title {
			font-size: 1.2rem;
		}

		.card {
			padding: 16px;
		}
	}
</style>
