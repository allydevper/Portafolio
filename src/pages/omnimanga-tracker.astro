---
import Layout from "../layouts/Layout.astro";

const features = [
	{
		title: "Deteccion automatica",
		description: "Detecta mangas en webs compatibles y prepara el alta en segundos.",
		badge: "Parser ready",
	},
	{
		title: "Biblioteca inteligente",
		description: "Busca, filtra y ordena tu biblioteca para encontrar cualquier lectura rapido.",
		badge: "Organizacion",
	},
	{
		title: "Detalle por obra",
		description: "Edita metadata, notas, portada y progreso desde una sola vista.",
		badge: "Control total",
	},
	{
		title: "Listas personalizadas",
		description: "Crea colecciones por genero, prioridad o temporada sin duplicar obras.",
		badge: "Flexible",
	},
	{
		title: "Actualizacion masiva",
		description: "Actualiza varias obras con resumen final de cambios, fallidas o sin fuente.",
		badge: "Productividad",
	},
	{
		title: "Export / Import JSON",
		description: "Respalda y restaura toda tu biblioteca cuando quieras.",
		badge: "Backup seguro",
	},
];

const faqs = [
	{
		question: "Que sitios soporta OmniManga Tracker?",
		answer:
			"Actualmente incluye soporte para MangaDex, Webtoon, Manga Plus y multiples parsers integrados.",
	},
	{
		question: "Puedo migrar mis datos entre navegadores?",
		answer:
			"Si. Puedes exportar un respaldo JSON e importarlo luego para recuperar tu biblioteca.",
	},
	{
		question: "La extension evita duplicados?",
		answer:
			"Si. El flujo de agregado detecta obras existentes y permite fusionar o vincular antes de guardar.",
	},
];
---

<Layout>
	<main class="omni-page min-h-screen text-[#E8E5DE]">
		<div class="ambient-layer ambient-one"></div>
		<div class="ambient-layer ambient-two"></div>
		<div class="relative z-10">
			<header class="sticky top-0 backdrop-blur-md bg-black/35 border-b border-white/10">
				<div class="max-w-6xl mx-auto px-4 md:px-8 py-4 flex items-center justify-between">
					<a href="/omnimanga-tracker" class="flex items-center gap-3">
						<img
							src="/omnimanga/app-logo-home.png"
							alt="OmniManga Tracker"
							class="h-5 w-auto opacity-95"
						/>
					</a>
					<nav class="hidden md:flex items-center gap-6 text-sm text-[#BFBAB0]">
						<a href="#features" class="hover:text-white transition-colors">Features</a>
						<a href="#como-funciona" class="hover:text-white transition-colors">Como funciona</a>
						<a href="#faq" class="hover:text-white transition-colors">FAQ</a>
					</nav>
				</div>
			</header>

			<section class="px-4 md:px-8 pt-16 pb-20">
				<div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-10 items-center">
					<div class="space-y-6">
						<p class="text-[10.5px] uppercase tracking-[0.24em] text-[#6F6B63]">
							Chrome Extension
						</p>
						<h1 class="text-4xl md:text-5xl font-semibold leading-tight">
							Centraliza tus mangas en un solo lugar.
						</h1>
						<p class="text-sm md:text-base text-[#BFBAB0] max-w-xl">
							OmniManga Tracker detecta lecturas desde webs compatibles, organiza tu
							biblioteca, administra listas y mantiene tu progreso actualizado.
						</p>
						<div class="flex flex-wrap gap-3">
							<a
								href="#"
								class="rounded-xl px-5 py-3 text-sm font-medium btn-primary inline-flex items-center gap-2"
							>
								<span aria-hidden="true" class="chrome-icon"></span>
								Instalar extension
							</a>
							<a
								href="#features"
								class="rounded-xl px-5 py-3 text-sm font-medium btn-secondary"
							>
								Ver funcionalidades
							</a>
						</div>
						<div class="flex flex-wrap gap-2 pt-2">
							<span class="status-badge badge-blue">MangaDex</span>
							<span class="status-badge badge-purple">Webtoon</span>
							<span class="status-badge badge-green">Manga Plus</span>
							<span class="status-badge">+ 37 parsers integrados</span>
						</div>
					</div>

					<div class="rounded-2xl border border-white/12 bg-white/[0.04] p-4 shadow-xl">
						<div class="rounded-xl border border-white/10 bg-[#120A1F] min-h-[320px] grid place-items-center text-center p-6">
							<div>
								<img
									src="/omnimanga/app-logo.png"
									alt="Logo de OmniManga Tracker"
									class="mx-auto mb-4 w-24 h-24 rounded-2xl border border-white/10"
								/>
								<img
									src="/omnimanga/app-logo-home.png"
									alt="Texto OmniManga Tracker"
									class="mx-auto mb-4 h-8 w-auto opacity-95"
								/>
								<p class="text-sm text-[#BFBAB0]">
									Placeholder de screenshot del sidepanel
								</p>
								<p class="text-xs text-[#6F6B63] mt-2">
									Recomendado: captura real de biblioteca + progreso
								</p>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section class="px-4 md:px-8 pb-16">
				<div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-6">
					<div class="content-card">
						<p class="text-[10.5px] uppercase tracking-[0.2em] text-[#6F6B63] mb-3">Problema</p>
						<h2 class="text-2xl font-semibold mb-3">Tus lecturas estan dispersas entre sitios</h2>
						<p class="text-sm text-[#BFBAB0]">
							Cambiar entre pestañas, listas y marcadores hace dificil mantener tu progreso
							real al dia.
						</p>
					</div>
					<div class="content-card">
						<p class="text-[10.5px] uppercase tracking-[0.2em] text-[#6F6B63] mb-3">Solucion</p>
						<h2 class="text-2xl font-semibold mb-3">Unifica todo en un panel lateral</h2>
						<p class="text-sm text-[#BFBAB0]">
							OmniManga Tracker concentra deteccion, biblioteca, listas y actualizaciones en
							un flujo simple.
						</p>
					</div>
				</div>
			</section>

			<section id="features" class="px-4 md:px-8 pb-16">
				<div class="max-w-6xl mx-auto">
					<h2 class="text-3xl font-semibold mb-8">Funcionalidades clave</h2>
					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
						{
							features.map((feature) => (
								<article class="content-card">
									<p class="status-badge badge-purple inline-flex mb-3">{feature.badge}</p>
									<h3 class="text-lg font-medium mb-2">{feature.title}</h3>
									<p class="text-sm text-[#BFBAB0]">{feature.description}</p>
								</article>
							))
						}
					</div>
				</div>
			</section>

			<section id="como-funciona" class="px-4 md:px-8 pb-16">
				<div class="max-w-6xl mx-auto">
					<h2 class="text-3xl font-semibold mb-8">Como funciona</h2>
					<div class="grid md:grid-cols-3 gap-4">
						<div class="content-card">
							<p class="status-badge mb-3">Paso 1</p>
							<h3 class="text-lg font-medium mb-2">Detecta una obra</h3>
							<p class="text-sm text-[#BFBAB0]">Abre una web compatible y deja que OmniManga la identifique.</p>
						</div>
						<div class="content-card">
							<p class="status-badge mb-3">Paso 2</p>
							<h3 class="text-lg font-medium mb-2">Guarda en tu biblioteca</h3>
							<p class="text-sm text-[#BFBAB0]">Revisa metadatos, evita duplicados y organiza por listas.</p>
						</div>
						<div class="content-card">
							<p class="status-badge mb-3">Paso 3</p>
							<h3 class="text-lg font-medium mb-2">Actualiza progreso</h3>
							<p class="text-sm text-[#BFBAB0]">Marca capitulos, actualiza en lote y exporta respaldo JSON.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="faq" class="px-4 md:px-8 pb-16">
				<div class="max-w-6xl mx-auto">
					<h2 class="text-3xl font-semibold mb-8">FAQ</h2>
					<div class="space-y-4">
						{
							faqs.map((faq) => (
								<details class="content-card">
									<summary class="cursor-pointer font-medium">{faq.question}</summary>
									<p class="text-sm text-[#BFBAB0] mt-3">{faq.answer}</p>
								</details>
							))
						}
					</div>
				</div>
			</section>

			<section class="px-4 md:px-8 pb-20">
				<div class="max-w-6xl mx-auto content-card text-center">
					<p class="text-[10.5px] uppercase tracking-[0.22em] text-[#6F6B63] mb-3">
						Empieza hoy
					</p>
					<h2 class="text-3xl font-semibold mb-4">Empieza a organizar tu lectura hoy</h2>
					<p class="text-sm text-[#BFBAB0] mb-6">
						Centraliza tus mangas y enfocate en leer, no en ordenar pestañas.
					</p>
					<div class="flex justify-center gap-3 flex-wrap">
						<a href="#" class="rounded-xl px-5 py-3 text-sm font-medium btn-primary inline-flex items-center gap-2">
							<span aria-hidden="true" class="chrome-icon"></span>
							Instalar extension
						</a>
						<a href="#features" class="rounded-xl px-5 py-3 text-sm font-medium btn-secondary">
							Ver funcionalidades
						</a>
					</div>
				</div>
			</section>

			<footer class="border-t border-white/10 px-4 md:px-8 py-8 text-center text-sm text-[#6F6B63]">
				OmniManga Tracker - MangaTracker v1.0.0
			</footer>
		</div>
	</main>
</Layout>

<style>
	@import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap");

	.omni-page {
		position: relative;
		background: linear-gradient(180deg, #160b26 0%, #0e0718 45%, #0a0512 100%);
		font-family: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif;
		overflow-x: hidden;
	}

	.ambient-layer {
		position: absolute;
		pointer-events: none;
		filter: blur(60px);
		opacity: 0.36;
	}

	.ambient-one {
		width: 380px;
		height: 380px;
		background: radial-gradient(circle, #7b3fbf 0%, rgba(123, 63, 191, 0) 72%);
		top: -120px;
		left: -70px;
	}

	.ambient-two {
		width: 480px;
		height: 480px;
		background: radial-gradient(circle, #b089ec 0%, rgba(176, 137, 236, 0) 76%);
		bottom: -190px;
		right: -120px;
	}

	.content-card {
		border-radius: 16px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(255, 255, 255, 0.04);
		padding: 24px;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18);
	}

	.btn-primary {
		color: #f8f3ff;
		background: #7b3fbf;
		box-shadow:
			0 1px 0 rgba(255, 255, 255, 0.1) inset,
			0 2px 8px rgba(49, 19, 78, 0.45),
			0 0 0 1px rgba(123, 63, 191, 0.45);
		transition: background-color 0.2s ease;
	}

	.btn-primary:hover {
		background: #6d31b1;
	}

	.btn-secondary {
		color: #e8e5de;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.1);
		transition: background-color 0.2s ease;
	}

	.btn-secondary:hover {
		background: rgba(255, 255, 255, 0.08);
	}

	.status-badge {
		display: inline-flex;
		align-items: center;
		border-radius: 10px;
		padding: 4px 10px;
		font-size: 12px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(255, 255, 255, 0.06);
		color: #bfbab0;
	}

	.badge-green {
		border-color: rgba(74, 200, 130, 0.35);
		background: rgba(74, 200, 130, 0.14);
		color: #6be3a1;
	}

	.badge-blue {
		border-color: rgba(90, 140, 255, 0.35);
		background: rgba(90, 140, 255, 0.14);
		color: #9bb4ff;
	}

	.badge-purple {
		border-color: rgba(138, 80, 200, 0.5);
		background: rgba(123, 63, 191, 0.18);
		color: #c9a8f5;
	}

	.chrome-icon {
		width: 14px;
		height: 14px;
		border-radius: 999px;
		background:
			conic-gradient(
				from 45deg,
				#fbbc04 0deg 120deg,
				#34a853 120deg 240deg,
				#ea4335 240deg 360deg
			);
		position: relative;
		display: inline-block;
	}

	.chrome-icon::after {
		content: "";
		position: absolute;
		inset: 3px;
		background: #4285f4;
		border-radius: 999px;
	}
</style>
