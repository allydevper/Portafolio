---
import Layout from "../layouts/Layout.astro";
import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";

const features = [
  { title: "Deteccion automatica", description: "Reconoce mangas en webs compatibles y prepara el registro sin pasos manuales.", icon: "✦" },
  { title: "Biblioteca inteligente", description: "Buscador, filtros por estado y orden por actividad para una gestion rapida.", icon: "▦" },
  { title: "Detalle por obra", description: "Edita metadata, portada, notas y progreso desde una sola vista clara.", icon: "✎" },
  { title: "Listas personalizadas", description: "Agrupa por objetivo, genero o prioridad sin duplicar obras en tu biblioteca.", icon: "◫" },
  { title: "Actualizacion masiva", description: "Ejecuta refresh por lotes y revisa el resumen final por resultado.", icon: "↻" },
  { title: "Export / Import JSON", description: "Haz respaldo completo y restaura datos cuando cambies de equipo o perfil.", icon: "◉" }
];

const faqs = [
  { question: "Que sitios soporta OmniManga Tracker?", answer: "Incluye compatibilidad con MangaDex, Webtoon, Manga Plus y decenas de parsers integrados." },
  { question: "Puedo migrar toda mi biblioteca?", answer: "Si. Puedes exportar un JSON de respaldo e importarlo en cualquier momento." },
  { question: "Como evita duplicados?", answer: "Durante el agregado detecta coincidencias y permite fusionar, vincular o crear un registro nuevo." }
];

const sliderImages = [
  "/omnimanga/slider/1.png",
  "/omnimanga/slider/2.png",
  "/omnimanga/slider/3.png",
  "/omnimanga/slider/4.png",
  "/omnimanga/slider/5.png"
];

const sliderCaptions = [
  { title: "Biblioteca central", subtitle: "Vista principal con progreso y estados" },
  { title: "Busqueda y filtros", subtitle: "Encuentra obras rapido por criterios" },
  { title: "Detalle de lectura", subtitle: "Capitulos, metadata y control manual" },
  { title: "Listas personalizadas", subtitle: "Organiza por prioridad o categoria" },
  { title: "Ajustes y respaldo", subtitle: "Exporta e importa tu backup JSON" }
];
---

<Layout>
  <main class="omni-page text-[#E8E5DE]">
    <div class="ambient ambient-top"></div>
    <div class="ambient ambient-bottom"></div>

    <header class="nav-wrap">
      <div class="container nav-inner">
        <a href="/omnimanga-tracker" class="brand">
          <img src="/omnimanga/app-logo-home.png" alt="OmniManga Tracker" class="brand-wordmark" />
        </a>
        <nav class="desktop-nav">
          <a href="#features">Features</a>
          <a href="#capturas">Capturas</a>
          <a href="#como-funciona">Como funciona</a>
          <a href="#faq">FAQ</a>
        </nav>
      </div>
    </header>

    <section class="container hero">
      <div class="hero-copy">
        <p class="eyebrow">Chrome Extension</p>
        <h1>Centraliza tus mangas en un solo lugar.</h1>
        <p class="lead">OmniManga Tracker detecta lecturas en webs compatibles y las organiza en una biblioteca lateral con progreso, listas y actualizaciones en lote.</p>
        <div class="hero-actions">
          <a href="#" class="btn btn-primary"><span aria-hidden="true" class="chrome-icon"></span>Instalar extension</a>
          <a href="#features" class="btn btn-secondary">Ver funcionalidades</a>
        </div>
        <div class="badge-row">
          <span class="status-badge badge-blue">MangaDex</span>
          <span class="status-badge badge-purple">Webtoon</span>
          <span class="status-badge badge-green">Manga Plus</span>
          <span class="status-badge">+37 parsers</span>
        </div>
      </div>

      <div class="hero-visual">
        <div class="mockup-screen">
          <div class="swiper hero-swiper" id="hero-swiper">
            <div class="swiper-wrapper">
              {sliderImages.map((image, index) => (
                <div class="swiper-slide" aria-label={`Captura ${index + 1}`}>
                  <img src={image} alt={`Captura de OmniManga Tracker ${index + 1}`} loading={index === 0 ? "eager" : "lazy"} />
                </div>
              ))}
            </div>
            <div class="swiper-button-prev" aria-label="Slide anterior"></div>
            <div class="swiper-button-next" aria-label="Slide siguiente"></div>
            <div class="swiper-pagination"></div>
          </div>
          <div class="slider-meta">
            <p id="slider-title" class="mockup-label">{sliderCaptions[0].title}</p>
            <p id="slider-subtitle" class="mockup-help">{sliderCaptions[0].subtitle}</p>
          </div>
        </div>
        <div class="mockup-chip left-chip logo-chip">
          <img src="/omnimanga/app-logo.png" alt="OmniManga Tracker logo" />
        </div>
      </div>
    </section>

    <section class="container trust">
      <p class="eyebrow">Problema / Solucion</p>
      <div class="split">
        <article class="panel">
          <h2>Tus lecturas estan dispersas entre sitios</h2>
          <p>El progreso se pierde entre pestanas, marcadores y listas no conectadas.</p>
        </article>
        <article class="panel">
          <h2>Unifica todo en un flujo simple</h2>
          <p>OmniManga concentra deteccion, organizacion y seguimiento en un solo panel lateral.</p>
        </article>
      </div>
    </section>

    <section id="features" class="container section">
      <div class="section-head">
        <p class="eyebrow">Features</p>
        <h2>Todo lo necesario para gestionar tus lecturas</h2>
      </div>
      <div class="feature-grid">
        {features.map((feature) => (
          <article class="feature-card">
            <div class="feature-icon" aria-hidden="true">{feature.icon}</div>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section id="capturas" class="container section">
      <div class="section-head">
        <p class="eyebrow">Product Preview</p>
        <h2>Espacios listos para capturas reales de la extension</h2>
      </div>
      <div class="capture-layout">
        <div class="capture-main panel-dashed"><p>CAPTURA DESKTOP</p><span>Biblioteca + filtros + cards de progreso</span></div>
        <div class="capture-side">
          <div class="panel-dashed small"><p>CAPTURA DETALLE</p><span>Editor de obra y capitulos</span></div>
          <div class="panel-dashed small"><p>CAPTURA AJUSTES</p><span>Backup JSON y preferencias</span></div>
        </div>
      </div>
    </section>

    <section id="como-funciona" class="container section">
      <div class="section-head">
        <p class="eyebrow">How it works</p>
        <h2>Tres pasos para empezar rapido</h2>
      </div>
      <div class="steps">
        <article class="step-card"><span class="step-index">01</span><h3>Detecta una obra</h3><p>Visita una web compatible y deja que el parser identifique la lectura.</p></article>
        <article class="step-card"><span class="step-index">02</span><h3>Guarda y organiza</h3><p>Revisa metadatos, evita duplicados y asigna la obra a tu lista.</p></article>
        <article class="step-card"><span class="step-index">03</span><h3>Actualiza progreso</h3><p>Marca capitulos, ejecuta refresh por lotes y exporta respaldo.</p></article>
      </div>
    </section>

    <section id="faq" class="container section">
      <div class="section-head"><p class="eyebrow">FAQ</p><h2>Preguntas frecuentes</h2></div>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="container section final-cta">
      <div class="panel final-panel">
        <p class="eyebrow">Empieza hoy</p>
        <h2>Organiza tu lectura sin friccion</h2>
        <p>Pasa de pestanas dispersas a una biblioteca centralizada con progreso y listas claras.</p>
        <div class="hero-actions">
          <a href="#" class="btn btn-primary"><span aria-hidden="true" class="chrome-icon"></span>Instalar extension</a>
          <a href="#capturas" class="btn btn-secondary">Ver capturas</a>
        </div>
      </div>
    </section>

    <footer class="container footer">OmniManga Tracker - MangaTracker v0.1.0</footer>
  </main>
</Layout>

<style>
@import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap");
.omni-page { position: relative; min-height: 100vh; background: linear-gradient(180deg, #160b26 0%, #0e0718 46%, #0a0512 100%); font-family: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif; overflow-x: hidden; padding-bottom: 40px; }
.container { width: min(1120px, calc(100% - 2.5rem)); margin-inline: auto; }
.ambient { position: fixed; pointer-events: none; filter: blur(56px); opacity: .35; z-index: 0; }
.ambient-top { width: 360px; height: 360px; top: -120px; left: -80px; background: radial-gradient(circle, #7b3fbf 0%, rgba(123,63,191,0) 72%); }
.ambient-bottom { width: 440px; height: 440px; right: -120px; bottom: -200px; background: radial-gradient(circle, #b089ec 0%, rgba(176,137,236,0) 74%); }
.nav-wrap { position: sticky; top: 0; z-index: 20; backdrop-filter: blur(10px); background: rgba(7,4,14,.55); border-bottom: 1px solid rgba(255,255,255,.09); }
.nav-inner { display: flex; align-items: center; justify-content: space-between; padding-block: 14px; }
.brand { display: flex; align-items: center; gap: 10px; }
.brand-icon { width: 34px; height: 34px; border-radius: 10px; border: 1px solid rgba(255,255,255,.18); }
.brand-wordmark { height: 18px; width: auto; opacity: .95; }
.desktop-nav { display: flex; gap: 22px; font-size: 14px; color: #bfbab0; }
.desktop-nav a:hover { color: #fff; }
.hero { position: relative; z-index: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 42px; padding-top: 68px; padding-bottom: 72px; align-items: center; }
.eyebrow { font-size: 10.5px; letter-spacing: .2em; text-transform: uppercase; color: #8f8a81; margin-bottom: 14px; }
.hero-copy h1 { font-size: clamp(2.1rem, 4.4vw, 3.35rem); line-height: 1.08; font-weight: 600; max-width: 16ch; }
.lead { margin-top: 20px; font-size: 15px; line-height: 1.65; color: #c8c2b7; max-width: 56ch; }
.hero-actions { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
.btn { display: inline-flex; align-items: center; gap: 8px; border-radius: 12px; padding: 12px 18px; font-size: 14px; font-weight: 500; }
.btn-primary { color: #f8f3ff; background: #7b3fbf; box-shadow: 0 1px 0 rgba(255,255,255,.1) inset, 0 2px 10px rgba(49,19,78,.45), 0 0 0 1px rgba(123,63,191,.45); }
.btn-primary:hover { background: #6d31b1; }
.btn-secondary { color: #e8e5de; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.1); }
.btn-secondary:hover { background: rgba(255,255,255,.08); }
.chrome-icon { width: 14px; height: 14px; border-radius: 999px; background: conic-gradient(from 45deg, #fbbc04 0deg 120deg, #34a853 120deg 240deg, #ea4335 240deg 360deg); position: relative; display: inline-block; }
.chrome-icon::after { content: ""; position: absolute; inset: 3px; border-radius: 999px; background: #4285f4; }
.badge-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
.status-badge { display: inline-flex; align-items: center; border-radius: 10px; padding: 4px 10px; font-size: 12px; border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.06); color: #bfbab0; }
.badge-green { border-color: rgba(74,200,130,.35); background: rgba(74,200,130,.14); color: #6be3a1; }
.badge-blue { border-color: rgba(90,140,255,.35); background: rgba(90,140,255,.14); color: #9bb4ff; }
.badge-purple { border-color: rgba(138,80,200,.5); background: rgba(123,63,191,.18); color: #c9a8f5; }
.hero-visual { position: relative; max-width: 300px; width: 100%; justify-self: end; }
.mockup-screen { position: relative; z-index: 0; border-radius: 16px; border: 1px solid rgba(255,255,255,.14); background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.02)), radial-gradient(circle at 20% 10%, rgba(201,168,245,.18), rgba(201,168,245,0)); text-align: center; padding: 0; overflow: hidden; }
.hero-swiper { width: 100%; height: 400px; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,.12); background: #0d0717; --swiper-navigation-size: 18px; --swiper-navigation-color: #e8e5de; --swiper-pagination-color: #c9a8f5; --swiper-pagination-bullet-inactive-color: rgba(255,255,255,.45); --swiper-pagination-bullet-inactive-opacity: 1; }
.hero-swiper .swiper-slide { display: grid; place-items: center; background: #0d0717; box-sizing: border-box; }
.hero-swiper .swiper-slide img { width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; }
.hero-swiper .swiper-button-prev,
.hero-swiper .swiper-button-next { width: 32px; height: 32px; margin-top: 0; top: 50%; transform: translateY(-50%); background: rgba(12, 7, 22, 0.72); border: 1px solid rgba(255,255,255,.16); border-radius: 999px; }
.hero-swiper .swiper-button-prev::after,
.hero-swiper .swiper-button-next::after { font-size: 12px; font-weight: 700; }
.hero-swiper .swiper-pagination { bottom: 6px !important; }
.slider-meta { padding: 12px 14px 14px; background: rgba(9, 5, 16, 0.62); border-top: 1px solid rgba(255,255,255,.08); }
.mockup-label { font-size: 12px; letter-spacing: .14em; color: #c9a8f5; }
.mockup-help { margin-top: 8px; font-size: 13px; color: #9e988d; }
.mockup-chip { position: absolute; font-size: 11px; padding: 7px 10px; border-radius: 999px; border: 1px solid rgba(255,255,255,.14); background: rgba(15,8,27,.7); color: #d7cfbf; }
.logo-chip { z-index: 2; padding: 4px; width: 60px; height: 60px; display: grid; place-items: center; border-radius: 12px; }
.logo-chip img { width: 100%; height: 100%; object-fit: cover; border-radius: 9px; display: block; }
.left-chip { right: -20px; top: -18px; }
.right-chip { right: -8px; bottom: 16px; }
.section { position: relative; z-index: 1; padding-top: 24px; padding-bottom: 38px; }
.trust { position: relative; z-index: 1; padding-bottom: 30px; }
.split { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.panel { border-radius: 16px; border: 1px solid rgba(255,255,255,.12); background: rgba(255,255,255,.04); padding: 26px; }
.panel h2 { font-size: 1.45rem; line-height: 1.25; }
.panel p { margin-top: 11px; font-size: 14px; line-height: 1.6; color: #c2bcae; }
.section-head h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); max-width: 24ch; line-height: 1.2; }
.feature-grid { margin-top: 22px; display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 12px; }
.feature-card { border-radius: 14px; border: 1px solid rgba(255,255,255,.09); background: rgba(255,255,255,.03); padding: 20px; }
.feature-icon { width: 30px; height: 30px; display: grid; place-items: center; border-radius: 10px; background: rgba(123,63,191,.18); color: #d9bcff; font-size: 16px; }
.feature-card h3 { margin-top: 14px; font-size: 1rem; }
.feature-card p { margin-top: 8px; font-size: 14px; line-height: 1.55; color: #b9b3a8; }
.capture-layout { margin-top: 22px; display: grid; grid-template-columns: 1.15fr .85fr; gap: 14px; }
.capture-main,.panel-dashed { border-radius: 16px; border: 1px dashed rgba(201,168,245,.55); background: rgba(255,255,255,.02); display: grid; place-items: center; text-align: center; }
.capture-main { min-height: 310px; padding: 24px; }
.capture-side { display: grid; gap: 14px; }
.panel-dashed.small { min-height: 148px; padding: 18px; }
.panel-dashed p { font-size: 12px; letter-spacing: .13em; color: #c9a8f5; }
.panel-dashed span { margin-top: 8px; font-size: 13px; color: #a09a8f; }
.steps { margin-top: 22px; display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 12px; }
.step-card { border-radius: 14px; border: 1px solid rgba(255,255,255,.08); background: rgba(255,255,255,.03); padding: 20px; }
.step-index { font-size: 12px; letter-spacing: .14em; color: #c9a8f5; }
.step-card h3 { margin-top: 10px; font-size: 1rem; }
.step-card p { margin-top: 8px; font-size: 14px; line-height: 1.55; color: #b9b3a8; }
.faq-list { margin-top: 22px; display: grid; gap: 10px; }
.faq-item { border-radius: 14px; border: 1px solid rgba(255,255,255,.1); background: rgba(255,255,255,.03); padding: 18px; }
.faq-item summary { cursor: pointer; font-size: 15px; font-weight: 500; }
.faq-item p { margin-top: 10px; font-size: 14px; color: #bab4aa; line-height: 1.6; }
.final-cta { padding-top: 18px; }
.final-panel { text-align: center; }
.final-panel h2 { font-size: clamp(1.8rem, 3.2vw, 2.4rem); }
.final-panel p { margin-inline: auto; max-width: 56ch; }
.final-panel .hero-actions { justify-content: center; }
.footer { position: relative; z-index: 1; margin-top: 16px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,.1); color: #8a8478; font-size: 13px; text-align: center; }
@media (max-width: 1024px) { .hero { grid-template-columns: 1fr; gap: 28px; padding-top: 44px; } .hero-visual { justify-self: center; max-width: 380px; } .hero-swiper { height: 360px; } .feature-grid,.steps { grid-template-columns: repeat(2,minmax(0,1fr)); } .capture-layout,.split { grid-template-columns: 1fr; } }
@media (max-width: 740px) { .container { width: min(1120px, calc(100% - 1.4rem)); } .desktop-nav { display: none; } .feature-grid,.steps { grid-template-columns: 1fr; } .hero-actions { width: 100%; } .btn { justify-content: center; width: 100%; } .hero-visual { max-width: min(100%, 320px); } .hero-swiper { height: 320px; } .left-chip,.right-chip { position: static; display: inline-flex; margin-top: 10px; margin-right: 6px; } .hero-visual { text-align: center; } }
</style>

<script>
  import Swiper from "swiper";
  import { Autoplay, Navigation, Pagination } from "swiper/modules";

  const captions = [
    { title: "Biblioteca central", subtitle: "Vista principal con progreso y estados" },
    { title: "Busqueda y filtros", subtitle: "Encuentra obras rapido por criterios" },
    { title: "Detalle de lectura", subtitle: "Capitulos, metadata y control manual" },
    { title: "Listas personalizadas", subtitle: "Organiza por prioridad o categoria" },
    { title: "Ajustes y respaldo", subtitle: "Exporta e importa tu backup JSON" }
  ];

  function initHeroSwiper() {
    const el = document.getElementById("hero-swiper");
    const titleEl = document.getElementById("slider-title");
    const subtitleEl = document.getElementById("slider-subtitle");
    if (!el || el.dataset.swiperReady === "true") return;

    const nextBtn = el.querySelector(".swiper-button-next") as HTMLElement | null;
    const prevBtn = el.querySelector(".swiper-button-prev") as HTMLElement | null;
    const paginationEl = el.querySelector(".swiper-pagination") as HTMLElement | null;

    const swiper = new Swiper(el, {
      modules: [Autoplay, Navigation, Pagination],
      loop: true,
      speed: 1000,
      autoplay: {
        delay: 3200,
        disableOnInteraction: false
      },
      navigation: {
        nextEl: nextBtn,
        prevEl: prevBtn
      },
      pagination: {
        el: paginationEl,
        clickable: true
      }
    });

    el.dataset.swiperReady = "true";

    const updateCaption = () => {
      if (!titleEl || !subtitleEl) return;
      const idx = swiper.realIndex ?? 0;
      const current = captions[idx] ?? captions[0];
      titleEl.textContent = current.title;
      subtitleEl.textContent = current.subtitle;
    };

    updateCaption();
    swiper.on("slideChange", updateCaption);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initHeroSwiper);
  } else {
    initHeroSwiper();
  }
</script>
