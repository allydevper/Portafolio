	];

	function initMobileNav() {
		const toggle = document.getElementById("nav-toggle");
		const panel = document.getElementById("mobile-nav-dropdown");
		if (!toggle || !panel || toggle.dataset.navReady === "true") return;
		toggle.dataset.navReady = "true";
		const menuToggle = toggle;
		const menuPanel = panel;

		function setOpen(open: boolean) {
			menuToggle.setAttribute("aria-expanded", String(open));
			menuToggle.classList.toggle("is-open", open);
			menuPanel.hidden = !open;
		}

		menuToggle.addEventListener("click", (e) => {
			e.stopPropagation();
			setOpen(menuPanel.hidden);
		});

		menuPanel.querySelectorAll("a").forEach((link) => {
			link.addEventListener("click", () => setOpen(false));
		});

		document.addEventListener("click", (e) => {
			if (menuPanel.hidden) return;
			const el = e.target as Element;
			if (el.closest("#nav-toggle") || el.closest("#mobile-nav-dropdown"))
				return;
			setOpen(false);
		});

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !menuPanel.hidden) setOpen(false);
		});

		window.addEventListener("resize", () => {
			if (window.matchMedia("(min-width: 741px)").matches) setOpen(false);
		});
	}

	function initHeroLightbox() {
		const root = document.getElementById("hero-lightbox");
		const fullImg = root?.querySelector(
			".hero-lightbox-img",
		) as HTMLImageElement | null;
		const closeBtn = root?.querySelector(
			".hero-lightbox-close",
		) as HTMLButtonElement | null;
		const swiperEl = document.getElementById("hero-swiper");
		if (
			!root ||
			!fullImg ||
			!closeBtn ||
			!swiperEl ||
			root.dataset.lightboxReady === "true"
		)
			return;
		root.dataset.lightboxReady = "true";

		const box = root;
		const img = fullImg;
		const xbtn = closeBtn;
		const swiper = swiperEl;

		let lastFocus: HTMLElement | null = null;

		function open(src: string, alt: string) {
			lastFocus =
				document.activeElement instanceof HTMLElement
					? document.activeElement
					: null;
			img.src = src;
			img.alt = alt;
			box.hidden = false;
			document.body.style.overflow = "hidden";
			xbtn.focus();
		}

		function close() {
			box.hidden = true;
			document.body.style.overflow = "";
			img.removeAttribute("src");
			img.alt = "";
			lastFocus?.focus();
			lastFocus = null;
		}

		swiper.addEventListener("click", (e) => {
			const btn = (e.target as HTMLElement).closest(".hero-slide-zoom");
			if (!btn) return;
			const thumb = btn.querySelector("img");
			if (!thumb) return;
			const src = thumb.currentSrc || thumb.getAttribute("src") || "";
			if (!src) return;
			open(src, thumb.alt || "");
		});

		xbtn.addEventListener("click", (e) => {
			e.stopPropagation();
			close();
		});

		box.addEventListener("click", (e) => {
			if (e.target === box) close();
		});

		img.addEventListener("click", (e) => e.stopPropagation());

		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && !box.hidden) close();
		});
	}

	/** Índice de la última fila del carrusel (clon de "manga" para loop sin salto). */
	const MORPH_LAST_INDEX = 4;
	const MORPH_INTERVAL_MS = 3200;

	function getMorphLineStepPx(track: HTMLElement) {
		const first = track.querySelector(".hero-morph-line");
		return first ? first.getBoundingClientRect().height : 0;
	}

	function initHeroMorph() {
		const track = document.getElementById("hero-morph-track");
		if (!track || track.dataset.morphReady === "true") return;
		track.dataset.morphReady = "true";
		if (window.matchMedia("(prefers-reduced-motion: reduce)").matches)
			return;
		let pos = 0;
		window.setInterval(() => {
			const step = getMorphLineStepPx(track);
			if (step < 1) return;
			if (pos === MORPH_LAST_INDEX) {
				track.style.transition = "none";
				track.style.transform = "translate3d(0,0,0)";
				void track.offsetWidth;
				requestAnimationFrame(() => {
					track.style.removeProperty("transition");
					requestAnimationFrame(() => {
						track.style.transform = `translate3d(0, -${step}px, 0)`;
					});
				});
				pos = 1;
				return;
			}
			const next = pos + 1;
			track.style.transform = `translate3d(0, -${next * step}px, 0)`;
			pos = next;
		}, MORPH_INTERVAL_MS);
	}

	function initHeroSwiper() {
		const el = document.getElementById("hero-swiper");
		const titleEl = document.getElementById("slider-title");
		const subtitleEl = document.getElementById("slider-subtitle");
		if (!el || el.dataset.swiperReady === "true") return;

		const wrap = el.closest(".hero-swiper-wrap");
		const nextBtn = (wrap?.querySelector(".swiper-button-next") ??
			el.querySelector(".swiper-button-next")) as HTMLElement | null;
		const prevBtn = (wrap?.querySelector(".swiper-button-prev") ??
			el.querySelector(".swiper-button-prev")) as HTMLElement | null;
		const paginationEl = el.querySelector(
			".swiper-pagination",
		) as HTMLElement | null;

		const swiper = new Swiper(el, {
			modules: [Autoplay, Navigation, Pagination],
			loop: true,
			autoHeight: true,
			speed: 1100,
			autoplay: {
				delay: 3300,
				disableOnInteraction: false,
			},
			navigation: {
				nextEl: nextBtn,
				prevEl: prevBtn,
				addIcons: false,
			},
			pagination: {
				el: paginationEl,
				clickable: true,
			},
		});

		el.dataset.swiperReady = "true";

		const updateCaption = () => {
			if (!titleEl || !subtitleEl) return;
			const idx = swiper.realIndex ?? 0;
			const current = captions[idx] ?? captions[0];
			titleEl.textContent = current.title;
			subtitleEl.textContent = current.subtitle;
		};

		updateCaption();
		swiper.on("slideChange", updateCaption);
	}

	function boot() {
		initMobileNav();
		initHeroLightbox();
		initHeroSwiper();
		initHeroMorph();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", boot);
	} else {
		boot();
	}
</script>
