---
import Layout from "../layouts/Layout.astro";
import "swiper/css";
import "swiper/css/navigation";
import "swiper/css/pagination";

const features = [
	{
		title: "Deteccion automatica",
		description:
			"Reconoce mangas en webs compatibles y prepara el registro sin pasos manuales.",
		icon: "✦",
	},
	{
		title: "Biblioteca inteligente",
		description:
			"Buscador, filtros por estado y orden por actividad para una gestion rapida.",
		icon: "▦",
	},
	{
		title: "Detalle por obra",
		description:
			"Edita metadata, portada, notas y progreso desde una sola vista clara.",
		icon: "✎",
	},
	{
		title: "Listas personalizadas",
		description:
			"Agrupa por objetivo, genero o prioridad sin duplicar obras en tu biblioteca.",
		icon: "◫",
	},
	{
		title: "Actualizacion masiva",
		description:
			"Ejecuta refresh por lotes y revisa el resumen final por resultado.",
		icon: "↻",
	},
	{
		title: "Export / Import JSON",
		description:
			"Haz respaldo completo y restaura datos cuando cambies de equipo o perfil.",
		icon: "◉",
	},
];

const faqs = [
	{
		question: "Que sitios soporta OmniManga Tracker?",
		answer: "Incluye compatibilidad con MangaDex, Webtoon, Manga Plus y decenas de parsers integrados.",
	},
	{
		question: "Puedo migrar toda mi biblioteca?",
		answer: "Si. Puedes exportar un JSON de respaldo e importarlo en cualquier momento.",
	},
	{
		question: "Como evita duplicados?",
		answer: "Durante el agregado detecta coincidencias y permite fusionar, vincular o crear un registro nuevo.",
	},
];

const sliderImages = [
	"/omnimanga/slider/1.png",
	"/omnimanga/slider/2.png",
	"/omnimanga/slider/3.png",
	"/omnimanga/slider/4.png",
	"/omnimanga/slider/5.png",
];

const sliderCaptions = [
	{
		title: "Biblioteca central",
		subtitle: "Vista principal con progreso y estados",
	},
	{
		title: "Busqueda y filtros",
		subtitle: "Encuentra obras rapido por criterios",
	},
	{
		title: "Detalle de lectura",
		subtitle: "Capitulos, metadata y control manual",
	},
	{
		title: "Listas personalizadas",
		subtitle: "Organiza por prioridad o categoria",
	},
	{
		title: "Ajustes y respaldo",
		subtitle: "Exporta e importa tu backup JSON",
	},
];

const featureCaptures = [
	{
		file: "con el boton actualizar puedes revisar si hay nuevos capitulos en tu lectura.png",
		title: "Actualizar novedades",
		caption: "Comprueba si hay capítulos nuevos con un solo botón.",
	},
	{
		file: "marca el capitulo en que te quedaste.png",
		title: "Progreso por capítulo",
		caption: "Marca dónde te quedaste y mantén el seguimiento al día.",
	},
	{
		file: "acceso a la fuente de tu lectura y actulizar el capitulo con un solo boton.png",
		title: "Fuente y capítulo",
		caption:
			"Abre la fuente de la lectura y actualiza el capítulo con un solo clic.",
	},
	{
		file: "grabaste un duplicado. puedes fusionar ambas y juntar tu obra.png",
		title: "Fusionar duplicados",
		caption:
			"Si registraste la misma obra dos veces, unifica registros sin perder datos.",
	},
	{
		file: "gestion_generos_de_obras.png",
		title: "Géneros en la biblioteca",
		caption:
			"Filtra, edita o fusiona etiquetas y ve cuántas obras usan cada género.",
	},
	{
		file: "organiza tu lectura en grupos para que puedas organizar mejor.png",
		title: "Grupos de lectura",
		caption: "Agrupa obras para ordenar listas largas con más claridad.",
	},
	{
		file: "anota referencias y detalles que puedas necesitar.png",
		title: "Notas y personajes",
		caption:
			"Guarda notas personales y referencias de personajes junto a cada obra.",
	},
	{
		file: "importar-exportar-config-json.png",
		title: "Copia de seguridad",
		caption:
			"Exporta o importa un JSON para respaldar datos y restaurarlos en otro perfil o equipo.",
	},
	{
		title: "Y muchas más opciones a descubrir",
		caption: "",
		teaser: true,
	},
].map((item) => ({
	...item,
	src:
		"file" in item && item.file
			? encodeURI(`/omnimanga/features/${item.file}`)
			: undefined,
}));

const howItWorksSteps = [
	{
		index: "01",
		title: "Registra o usa una web compatible",
		text: "Agrega un lector, scan o cualquier url, si no se puede leer informanos para que la agreguemos.",
		image: encodeURI(
			"/omnimanga/features/Agrega tu web para acceso; si tiene parse, úsala, si no, usa las predeterminadas o pide actualizaciónv2.png",
		),
		imageAlt:
			"Sitios integrados (MangaDex, Webtoon, Manga Plus) y formulario para solicitar nuevas webs con indicador de parser",
	},
	{
		index: "02",
		title: "Detecta una obra",
		text: "Visita una web compatible y deja que el parser identifique la lectura.",
		image: "/omnimanga/features/quickAdd.png",
		imageAlt:
			"Vista rápida: resultado de búsqueda en MangaDex con opciones para ver o añadir la obra",
	},
	{
		index: "03",
		title: "Actualiza progreso",
		text: "Marca capitulos, ejecuta refresh por lotes y exporta respaldo.",
		image: encodeURI(
			"/omnimanga/features/marca el capitulo en que te quedastev2.png",
		),
		imageAlt:
			"Sección Capítulos: barra de progreso, marcar o desmarcar todos y rejilla de capítulos leídos y pendientes",
	},
];
---

<Layout>
	<main class="omni-page text-[#E8E5DE]">
		<div class="ambient ambient-top"></div>
		<div class="ambient ambient-bottom"></div>

		<header class="nav-wrap">
			<div class="container nav-inner">
				<a href="/omnimanga-tracker" class="brand">
					<img
						src="/omnimanga/app-logo-home.png"
						alt="OmniManga Tracker"
						class="brand-wordmark"
					/>
				</a>
				<nav class="desktop-nav" aria-label="Secciones">
					<a href="#features">Features</a>
					<a href="#capturas">Capturas</a>
					<a href="#como-funciona">Como funciona</a>
					<a href="#faq">FAQ</a>
				</nav>
				<button
					type="button"
					class="nav-toggle"
					id="nav-toggle"
					aria-expanded="false"
					aria-controls="mobile-nav-dropdown"
				>
					<span class="nav-toggle-bars" aria-hidden="true"></span>
					<span class="sr-only">Menú de navegación</span>
				</button>
			</div>
			<div id="mobile-nav-dropdown" class="mobile-nav-dropdown" hidden>
				<div class="container mobile-nav-inner">
					<nav class="mobile-nav" aria-label="Secciones">
						<a href="#features">Features</a>
						<a href="#capturas">Capturas</a>
						<a href="#como-funciona">Como funciona</a>
						<a href="#faq">FAQ</a>
					</nav>
				</div>
			</div>
		</header>

		<section class="container hero">
			<div class="hero-copy">
				<p class="eyebrow">Chrome Extension</p>
				<h1
					class="hero-title"
					aria-label="Centraliza tus mangas, manhwas, manhuas o novelas en un solo lugar."
				>
					<span class="hero-title-inner" aria-hidden="true">
						<span class="hero-title-chunk">Centraliza tus</span>
						<span id="hero-morph" class="hero-morph">
							<span class="hero-morph-viewport">
								<span
									id="hero-morph-track"
									class="hero-morph-track"
								>
									<span class="hero-morph-line">mangas</span>
									<span class="hero-morph-line">manhwas</span>
									<span class="hero-morph-line">manhuas</span>
									<span class="hero-morph-line">novelas</span>
									<span
										class="hero-morph-line hero-morph-line--clone"
										aria-hidden="true">mangas</span
									>
								</span>
							</span>
						</span>
						<span class="hero-title-chunk">en un solo lugar.</span>
					</span>
				</h1>
				<p class="lead">
					OmniManga Tracker detecta lecturas en webs compatibles y las
					organiza en una biblioteca lateral con progreso, listas y
					actualizaciones en lote.
				</p>
				<div class="hero-actions">
					<a href="#" class="btn btn-primary"
						><span aria-hidden="true" class="chrome-icon"
						></span>Instalar extension</a
					>
					<a href="#features" class="btn btn-secondary"
						>Ver funcionalidades</a
					>
				</div>
				<div class="badge-row">
					<span class="status-badge badge-blue">MangaDex</span>
					<span class="status-badge badge-purple">Webtoon</span>
					<span class="status-badge badge-green">Manga Plus</span>
					<span class="status-badge">+37 parsers</span>
				</div>
			</div>

			<div class="hero-visual">
				<div class="mockup-screen">
					<div class="hero-swiper-wrap">
						<div class="swiper hero-swiper" id="hero-swiper">
							<div class="swiper-wrapper">
								{
									sliderImages.map((image, index) => (
										<div
											class="swiper-slide"
											aria-label={`Captura ${index + 1}`}
										>
											<button
												type="button"
												class="hero-slide-zoom"
												aria-label={`Ampliar captura ${index + 1}`}
											>
												<img
													src={image}
													alt={`Captura de OmniManga Tracker ${index + 1}`}
													loading={
														index === 0
															? "eager"
															: "lazy"
													}
												/>
											</button>
										</div>
									))
								}
							</div>
							<div class="swiper-pagination"></div>
						</div>
						<div
							class="swiper-button-prev hero-swiper-nav-out"
							aria-label="Slide anterior"
						>
							<span
								class="hero-swiper-nav-icon"
								aria-hidden="true">&lsaquo;</span
							>
						</div>
						<div
							class="swiper-button-next hero-swiper-nav-out"
							aria-label="Slide siguiente"
						>
							<span
								class="hero-swiper-nav-icon"
								aria-hidden="true">&rsaquo;</span
							>
						</div>
					</div>
					<div class="slider-meta">
						<p id="slider-title" class="mockup-label">
							{sliderCaptions[0].title}
						</p>
						<p id="slider-subtitle" class="mockup-help">
							{sliderCaptions[0].subtitle}
						</p>
					</div>
				</div>
				<div class="mockup-chip left-chip logo-chip">
					<img
						src="/omnimanga/app-logo.png"
						alt="OmniManga Tracker logo"
					/>
				</div>
			</div>
		</section>

		<section class="container trust">
			<p class="eyebrow">Problema / Solucion</p>
			<div class="split">
				<article class="panel">
					<h2>Tus lecturas estan dispersas entre sitios</h2>
					<p>
						El progreso se pierde entre pestanas, marcadores y
						listas no conectadas.
					</p>
				</article>
				<article class="panel">
					<h2>Unifica todo en un flujo simple</h2>
					<p>
						OmniManga concentra deteccion, organizacion y
						seguimiento en un solo panel lateral.
					</p>
				</article>
			</div>
		</section>

		<section id="features" class="container section">
			<div class="section-head">
				<p class="eyebrow">Funcionalidades</p>
				<h2>Todo lo necesario para gestionar tus lecturas</h2>
			</div>
			<div class="feature-grid">
				{
					features.map((feature) => (
						<article class="feature-card">
							<div class="feature-icon" aria-hidden="true">
								{feature.icon}
							</div>
							<h3>{feature.title}</h3>
							<p>{feature.description}</p>
						</article>
					))
				}
			</div>
		</section>

		<section id="capturas" class="container section">
			<div class="section-head">
				<p class="eyebrow">Capacidades</p>
				<h2>Funciones de la extensión en capturas reales</h2>
			</div>
			<div class="feature-capture-grid">
				{
					featureCaptures.map((item) => (
						<article
							class:list={[
								"feature-capture-card",
								item.teaser && "feature-capture-card--teaser",
							]}
						>
							{item.teaser ? (
								<div class="feature-capture-teaser">
									<h3>{item.title}</h3>
									{item.caption ? (
										<p>{item.caption}</p>
									) : null}
								</div>
							) : (
								<>
									<div class="feature-capture-media">
										<img
											src={item.src}
											alt={item.title}
											loading="lazy"
											decoding="async"
											class="feature-capture-img"
										/>
									</div>
									<div class="feature-capture-text">
										<h3>{item.title}</h3>
										{item.caption ? (
											<p>{item.caption}</p>
										) : null}
									</div>
								</>
							)}
						</article>
					))
				}
			</div>
		</section>

		<section id="como-funciona" class="container section">
			<div class="section-head">
				<p class="eyebrow">Como funciona</p>
				<h2>Tres pasos para empezar rapido</h2>
			</div>
			<div class="steps">
				{
					howItWorksSteps.map((step) => (
						<article class="step-card">
							{step.image ? (
								<div class="step-card-media">
									<img
										src={step.image}
										alt={step.imageAlt}
										loading="lazy"
										decoding="async"
										class="step-card-img"
									/>
								</div>
							) : null}
							<span class="step-index">{step.index}</span>
							<h3>{step.title}</h3>
							<p>{step.text}</p>
						</article>
					))
				}
			</div>
		</section>

		<section id="faq" class="container section">
			<div class="section-head">
				<p class="eyebrow">FAQ</p><h2>Preguntas frecuentes</h2>
			</div>
			<div class="faq-list">
				{
					faqs.map((faq) => (
						<details class="faq-item">
							<summary>{faq.question}</summary>
							<p>{faq.answer}</p>
						</details>
					))
				}
			</div>
		</section>

		<section class="container section final-cta">
			<div class="panel final-panel">
				<p class="eyebrow">Empieza hoy</p>
				<h2>Organiza tu lectura sin friccion</h2>
				<p>
					Pasa de pestanas dispersas a una biblioteca centralizada con
					progreso y listas claras.
				</p>
				<div class="hero-actions">
					<a href="#" class="btn btn-primary"
						><span aria-hidden="true" class="chrome-icon"
						></span>Instalar extension</a
					>
					<a href="#capturas" class="btn btn-secondary"
						>Ver capturas</a
					>
				</div>
			</div>
		</section>

		<footer class="container footer">
			OmniManga Tracker - MangaTracker v1.0.0
		</footer>
	</main>

	<div
		id="hero-lightbox"
		class="hero-lightbox"
		role="dialog"
		aria-modal="true"
		aria-label="Captura ampliada"
		hidden
	>
		<button type="button" class="hero-lightbox-close" aria-label="Cerrar"
			>&times;</button
		>
		<img class="hero-lightbox-img" alt="" decoding="async" />
	</div>
</Layout>

<style>
	@import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap");
	.omni-page {
		position: relative;
		min-height: 100vh;
		background-color: #0a0512;
		background-image:
			linear-gradient(
				180deg,
				rgba(22, 11, 38, 0.9) 0%,
				rgba(14, 7, 24, 0.97) 1%,
				rgba(10, 5, 18, 0.95) 100%
			),
			url("/omnimanga/back2.jpg");
		background-size: cover, cover;
		background-position: center, center;
		background-repeat: no-repeat;
		font-family: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif;
		overflow-x: hidden;
		padding-bottom: 40px;
	}
	.container {
		width: min(1120px, calc(100% - 2.5rem));
		margin-inline: auto;
	}
	.ambient {
		position: fixed;
		pointer-events: none;
		filter: blur(56px);
		opacity: 0.35;
		z-index: 0;
	}
	.ambient-top {
		width: 360px;
		height: 360px;
		top: -120px;
		left: -80px;
		background: radial-gradient(
			circle,
			#7b3fbf 0%,
			rgba(123, 63, 191, 0) 72%
		);
	}
	.ambient-bottom {
		width: 440px;
		height: 440px;
		right: -120px;
		bottom: -200px;
		background: radial-gradient(
			circle,
			#b089ec 0%,
			rgba(176, 137, 236, 0) 74%
		);
	}
	.nav-wrap {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(10px);
		background: rgba(7, 4, 14, 0.55);
		border-bottom: 1px solid rgba(255, 255, 255, 0.09);
	}
	.nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-block: 14px;
	}
	.brand {
		display: flex;
		align-items: center;
		gap: 10px;
	}
	.brand-icon {
		width: 34px;
		height: 34px;
		border-radius: 10px;
		border: 1px solid rgba(255, 255, 255, 0.18);
	}
	.brand-wordmark {
		height: 18px;
		width: auto;
		opacity: 0.95;
	}
	.desktop-nav {
		display: flex;
		gap: 22px;
		font-size: 14px;
		color: #bfbab0;
	}
	.desktop-nav a:hover {
		color: #fff;
	}
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	.nav-toggle {
		display: none;
		position: relative;
		align-items: center;
		justify-content: center;
		width: 44px;
		height: 44px;
		margin: 0;
		padding: 0;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 12px;
		background: rgba(255, 255, 255, 0.06);
		color: #e8e5de;
		cursor: pointer;
	}
	.nav-toggle:hover {
		background: rgba(255, 255, 255, 0.1);
	}
	.nav-toggle:focus-visible {
		outline: 2px solid #c9a8f5;
		outline-offset: 2px;
	}
	.nav-toggle-bars {
		display: block;
		width: 20px;
		height: 2px;
		border-radius: 1px;
		background: currentColor;
		box-shadow:
			0 -6px 0 currentColor,
			0 6px 0 currentColor;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			background 0.2s ease;
	}
	.nav-toggle.is-open .nav-toggle-bars {
		box-shadow: none;
		background:
			linear-gradient(currentColor, currentColor) 50% 50% / 100% 2px
				no-repeat,
			linear-gradient(currentColor, currentColor) 50% 50% / 2px 20px
				no-repeat;
		transform: rotate(45deg);
	}
	.mobile-nav-dropdown {
		border-top: 1px solid rgba(255, 255, 255, 0.08);
		background: rgba(7, 4, 14, 0.92);
		backdrop-filter: blur(12px);
	}
	.mobile-nav-dropdown[hidden] {
		display: none !important;
	}
	.mobile-nav-inner {
		padding-block: 12px 16px;
	}
	.mobile-nav {
		display: flex;
		flex-direction: column;
		gap: 4px;
	}
	.mobile-nav a {
		display: block;
		padding: 12px 14px;
		border-radius: 12px;
		font-size: 15px;
		font-weight: 500;
		color: #e8e5de;
		text-decoration: none;
		border: 1px solid transparent;
	}
	.mobile-nav a:hover {
		background: rgba(255, 255, 255, 0.06);
		color: #fff;
	}
	.mobile-nav a:focus-visible {
		outline: 2px solid #c9a8f5;
		outline-offset: 2px;
	}
	.hero {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: 1.15fr 0.85fr;
		gap: 42px;
		padding-top: 68px;
		padding-bottom: 72px;
		align-items: center;
	}
	.eyebrow {
		font-size: 10.5px;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: #8f8a81;
		margin-bottom: 14px;
	}
	.hero-copy h1 {
		font-size: clamp(2.1rem, 4.4vw, 3.35rem);
		line-height: 1.08;
		font-weight: 600;
		max-width: 22ch;
	}
	.hero-title-inner {
		display: inline-flex;
		flex-wrap: wrap;
		align-items: center;
		column-gap: 0.2em;
		row-gap: 0.2em;
	}
	.hero-title-chunk {
		display: inline;
	}
	.hero-morph {
		display: inline-block;
		position: relative;
		top: 0.08em;
		flex-shrink: 0;
	}
	.hero-morph-viewport {
		display: inline-block;
		overflow: hidden;
		min-width: 7.4ch;
