---
import Layout from "../../layouts/Layout.astro";
import { messages } from "./i18n";

const t = messages.es;
const p = t.privacy;
---

<Layout lang="es" title={p.pageTitle}>
	<script is:inline>
		(function () {
			try {
				var l = localStorage.getItem("omnimanga-lang");
				if (l === "en" || l === "es") {
					document.documentElement.lang = l;
					document.documentElement.dataset.locale = l;
				}
			} catch (e) {}
		})();
	</script>
	<span hidden data-i18n-doc-title="privacy.pageTitle"></span>
	<main class="privacy-page text-[#E8E5DE]">
		<header class="privacy-nav">
			<div class="container privacy-nav-inner">
				<a href="/omnimanga-tracker" class="brand">
					<img
						src="/omnimanga/app-logo-home.png"
						alt="OmniManga Tracker"
						class="brand-wordmark"
					/>
				</a>
				<div
					class="lang-switch"
					role="group"
					data-i18n="lang.aria"
					data-i18n-attr="aria-label"
					aria-label={t.lang.aria}
				>
					<button
						type="button"
						class="lang-btn is-active"
						data-lang-switch="es"
						aria-pressed="true"
						data-i18n="lang.es">{t.lang.es}</button
					>
					<button
						type="button"
						class="lang-btn"
						data-lang-switch="en"
						aria-pressed="false"
						data-i18n="lang.en">{t.lang.en}</button
					>
				</div>
			</div>
		</header>

		<section class="container section">
			<p class="eyebrow" data-i18n="privacy.eyebrow">{p.eyebrow}</p>
			<h1 data-i18n="privacy.title">{p.title}</h1>
			<p class="lead" data-i18n="privacy.lead">{p.lead}</p>
			<p class="responsible" data-i18n="privacy.responsible"
				>{p.responsible}</p
			>
		</section>

		<section class="container section">
			<div class="panel privacy-panel">
				<h2 data-i18n="privacy.s1Title">{p.s1Title}</h2>
				<ul>
					<li data-i18n="privacy.s1Li1">{p.s1Li1}</li>
					<li data-i18n="privacy.s1Li2">{p.s1Li2}</li>
				</ul>

				<h2 data-i18n="privacy.s2Title">{p.s2Title}</h2>
				<p data-i18n="privacy.s2Intro">{p.s2Intro}</p>
				<ul>
					<li data-i18n="privacy.s2Li1">{p.s2Li1}</li>
					<li data-i18n="privacy.s2Li2">{p.s2Li2}</li>
					<li data-i18n="privacy.s2Li3">{p.s2Li3}</li>
				</ul>

				<h2 data-i18n="privacy.s3Title">{p.s3Title}</h2>
				<p data-i18n="privacy.s3P1">{p.s3P1}</p>
				<p data-i18n="privacy.s3P2">{p.s3P2}</p>

				<h2 data-i18n="privacy.s4Title">{p.s4Title}</h2>
				<p data-i18n="privacy.s4P1">{p.s4P1}</p>
				<p data-i18n="privacy.s4P2">{p.s4P2}</p>

				<h2 data-i18n="privacy.s5Title">{p.s5Title}</h2>
				<p data-i18n="privacy.s5P">{p.s5P}</p>

				<h2 data-i18n="privacy.s6Title">{p.s6Title}</h2>
				<p data-i18n="privacy.s6P">{p.s6P}</p>

				<h2 data-i18n="privacy.s7Title">{p.s7Title}</h2>
				<p data-i18n="privacy.s7P">{p.s7P}</p>

				<h2 data-i18n="privacy.s8Title">{p.s8Title}</h2>
				<p>
					<span data-i18n="privacy.s8P">{p.s8P}</span>
					{" "}
					<a href="mailto:alamaswilmer@gmail.com"
						>alamaswilmer@gmail.com
					</a>
				</p>

				<p class="privacy-meta" data-i18n="privacy.meta">{p.meta}</p>
			</div>
		</section>

		<footer class="container footer">
			<a
				href="/omnimanga-tracker"
				class="back-link"
				data-i18n="privacy.back">{p.back}</a
			>
		</footer>
	</main>
</Layout>

<style is:global>
	html[data-locale="en"]:not([data-i18n-ready]) .privacy-page {
		visibility: hidden;
	}
</style>

<style>
	@import url("https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap");

	.privacy-page {
		min-height: 100vh;
		background: linear-gradient(180deg, #120a20 0%, #0a0512 100%);
		font-family: "Plus Jakarta Sans", ui-sans-serif, system-ui, sans-serif;
		padding-bottom: 36px;
	}
	.privacy-nav {
		position: sticky;
		top: 0;
		z-index: 20;
		backdrop-filter: blur(10px);
		background: rgba(7, 4, 14, 0.55);
		border-bottom: 1px solid rgba(255, 255, 255, 0.09);
	}
	.privacy-nav-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 16px;
		padding-block: 14px;
	}
	.brand {
		display: flex;
		align-items: center;
	}
	.brand-wordmark {
		height: 18px;
		width: auto;
		opacity: 0.95;
	}
	.lang-switch {
		display: inline-flex;
		align-items: center;
		gap: 2px;
		padding: 3px;
		border-radius: 10px;
		border: 1px solid rgba(255, 255, 255, 0.12);
		background: rgba(255, 255, 255, 0.04);
	}
	.lang-btn {
		margin: 0;
		padding: 6px 10px;
		border: 0;
		border-radius: 8px;
		background: transparent;
		color: #9e978c;
		font: inherit;
		font-size: 12px;
		font-weight: 600;
		letter-spacing: 0.06em;
		cursor: pointer;
		line-height: 1;
	}
	.lang-btn:hover {
		color: #e8e5de;
	}
	.lang-btn.is-active {
		background: rgba(201, 168, 245, 0.18);
		color: #f3ecff;
	}
	.lang-btn:focus-visible {
		outline: 2px solid #c9a8f5;
		outline-offset: 1px;
	}
	.container {
		width: min(900px, calc(100% - 2.5rem));
		margin-inline: auto;
	}
	.section {
		padding-top: 28px;
	}
	.eyebrow {
		margin: 0;
		font-size: 12px;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #bca0de;
	}
	h1 {
		margin: 10px 0 0;
		font-size: clamp(1.9rem, 3.2vw, 2.5rem);
	}
	.lead {
		margin-top: 14px;
		max-width: 70ch;
		line-height: 1.65;
		color: #bfb8ad;
	}
	.responsible {
		margin-top: 12px;
		font-size: 13px;
		color: #a99fba;
	}
	.panel {
		border-radius: 20px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background: rgba(255, 255, 255, 0.03);
		padding: 24px;
	}
	.privacy-panel {
		display: grid;
		gap: 12px;
	}
	.privacy-panel h2 {
		margin-top: 10px;
		font-size: 1rem;
		color: #ead7ff;
	}
	.privacy-panel p,
	.privacy-panel li {
		font-size: 14px;
		line-height: 1.65;
		color: #bfb8ad;
	}
	.privacy-panel ul {
		margin: 0;
		padding-left: 1.1rem;
		display: grid;
		gap: 8px;
	}
	.privacy-panel a {
		color: #c9a8f5;
		text-decoration: none;
	}
	.privacy-panel a:hover {
		text-decoration: underline;
	}
	.privacy-meta {
		margin-top: 6px;
		font-size: 12px;
		color: #8d8699;
	}
	.footer {
		margin-top: 24px;
		padding-top: 16px;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
		text-align: center;
	}
	.back-link {
		color: #c9a8f5;
		text-decoration: none;
	}
	.back-link:hover {
		text-decoration: underline;
	}
</style>

<script>
	import { initLangSwitcher } from "./i18n";

	function boot() {
		initLangSwitcher();
	}

	if (document.readyState === "loading") {
		document.addEventListener("DOMContentLoaded", boot);
	} else {
		boot();
	}
</script>
